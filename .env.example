# Gitea Configuration
GITEA_INSTANCE_URL=https://gitea.yourdomain.com
GITEA_TOKEN=your_gitea_personal_access_token_here

# Open-WebUI Configuration
OWUI_INSTANCE_URL=http://localhost:8080
OWUI_TOKEN=your_openwebui_api_key_here

# Notes Sync Configuration
# Knowledge Base ID to sync notes into (create a KB in Open-WebUI first, then grab its ID)
NOTES_SYNC_KB_ID=
# Sync interval in seconds (default: 300 = 5 minutes). Set to 0 to disable automatic sync.
NOTES_SYNC_INTERVAL=300

# Server Configuration
HOST=0.0.0.0
PORT=8090
LOG_LEVEL=info
